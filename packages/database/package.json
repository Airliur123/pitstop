{
  "name": "@pitstop/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed.ts",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@pitstop/config": "workspace:*",
    "drizzle-orm": "0.45.2",
    "mysql2": "3.23.1"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "rimraf": "6.1.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
