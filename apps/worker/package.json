    "ioredis": "5.11.1",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "eslint": "9.39.5",
    "rimraf": "6.1.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
