{
  "name": "@pitstop/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@fastify/cors": "11.3.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/static": "9.3.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-fastify": "11.1.28",
    "@nestjs/swagger": "11.4.6",
    "@pitstop/config": "workspace:*",
    "@pitstop/contracts": "workspace:*",
    "@pitstop/database": "workspace:*",
    "@pitstop/validation": "workspace:*",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "fastify": "5.10.0",
    "ioredis": "5.11.1",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@types/node": "26.1.1",
    "@types/supertest": "7.2.1",
    "eslint": "9.39.5",
    "rimraf": "6.1.3",
    "supertest": "7.2.2",
    "testcontainers": "12.0.4",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
