NODE_ENV=development

WEB_PORT=3000
ADMIN_PORT=3001
API_PORT=3002
API_PREFIX=api
API_VERSION=v1
API_SWAGGER_ENABLED=true
API_BODY_LIMIT_BYTES=1048576
API_MAX_QUERY_LENGTH=2048
NEXT_PUBLIC_API_BASE_URL=http://localhost:3002/api/v1
NEXT_PUBLIC_ENABLE_UI_CATALOG=false

MYSQL_DATABASE=pitstop
MYSQL_USER=pitstop
MYSQL_PASSWORD=pitstop_local_change_me
MYSQL_ROOT_PASSWORD=pitstop_root_local_change_me
DATABASE_URL=mysql://pitstop:pitstop_local_change_me@localhost:3306/pitstop

REDIS_URL=redis://localhost:6379
REDIS_CACHE_ENABLED=true
CACHE_CATEGORIES_TTL_SECONDS=300
CACHE_PLACE_DETAIL_TTL_SECONDS=60
CACHE_SEARCH_TTL_SECONDS=30
CACHE_RECOMMENDATION_TTL_SECONDS=30
CACHE_REDIS_TIMEOUT_MS=250

PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_RATE_LIMIT_MAX=60
RECOMMENDATION_RATE_LIMIT_MAX=30
PUBLIC_FALLBACK_RADIUS_METERS=10000
PUBLIC_MAX_SEARCH_LIMIT=50
PUBLIC_RECOMMENDATION_CANDIDATE_LIMIT=200
# Required in production; use a unique value of at least 32 UTF-8 bytes. Omit in development to
# generate a process-local ephemeral secret, which invalidates cursors after restart.
# PUBLIC_CURSOR_SIGNING_SECRET=replace-with-a-unique-production-secret
PUBLIC_BUDGET_MAX_AMOUNT=10000000
PUBLIC_LOCATION_LOGGING=false

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=pitstop-local
S3_ACCESS_KEY=pitstop-local
S3_SECRET_KEY=pitstop_minio_local_change_me
S3_FORCE_PATH_STYLE=true

MAIL_HOST=localhost
MAIL_PORT=1025

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
TRUST_PROXY=false
LOG_LEVEL=info
