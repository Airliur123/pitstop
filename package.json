{
  "name": "pitstop",
  "version": "0.0.0",
  "private": true,
  "description": "PitStop Mobile PWA and Admin MVP monorepo",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "turbo test",
    "test:integration": "pnpm --filter @pitstop/api test:integration",
    "test:api:integration": "pnpm --filter @pitstop/api test:integration",
    "test:e2e": "playwright test --config packages/testing/playwright.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo clean && rimraf .turbo coverage playwright-report test-results",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs --follow",
    "docker:reset": "docker compose down --volumes --remove-orphans",
    "db:generate": "pnpm --filter @pitstop/database db:generate",
    "db:migrate": "pnpm --filter @pitstop/database db:migrate",
    "db:seed": "pnpm --filter @pitstop/database db:seed",
    "db:test": "pnpm --filter @pitstop/database db:test"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.11",
    "eslint-plugin-simple-import-sort": "14.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "prettier": "3.9.6",
    "rimraf": "6.1.3",
    "turbo": "2.10.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0"
  }
}
